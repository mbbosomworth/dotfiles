" Allow clipboard usage
set clipboard+=unnamedplus

" No swap file
set noswapfile

" Undo settings
set undofile
set undodir=$HOME/.config/nvim/undo
set undolevels=10000
set undoreload=10000

" Line numbers
set relativenumber

" Tab settings
set autoindent
set expandtab
set tabstop=4
set softtabstop=4
set shiftwidth=4
